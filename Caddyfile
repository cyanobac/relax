# Global options. Trust Cloudflare's edge IPs so {client_ip} resolves to the real
# visitor (Cloudflare proxies all traffic, so the direct peer is always a CF IP).
# Keep this list in sync with https://www.cloudflare.com/ips/.
{
	servers {
		trusted_proxies static \
			173.245.48.0/20 103.21.244.0/22 103.22.200.0/22 103.31.4.0/22 \
			141.101.64.0/18 108.162.192.0/18 190.93.240.0/20 188.114.96.0/20 \
			197.234.240.0/22 198.41.128.0/17 162.158.0.0/15 104.16.0.0/13 \
			104.24.0.0/14 172.64.0.0/13 131.0.72.0/22 \
			2400:cb00::/32 2606:4700::/32 2803:f800::/32 2405:b500::/32 \
			2405:8100::/32 2a06:98c0::/29 2c0f:f248::/32
	}
}

{$DOMAIN} {
	# Public, unauthenticated: anyone can try the tool. Abuse is handled by the
	# per-IP rate limit, the in-flight cap, and Cloudflare in front — see README.

	# Access log to stdout (captured by `docker compose logs caddy`) so abuse is
	# visible and can feed fail2ban-style banning later.
	log {
		output stdout
		format json
	}

	# Security headers on every response.
	header {
		# HSTS: force HTTPS for a year (TLS is always on here).
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		# Don't let browsers MIME-sniff responses.
		X-Content-Type-Options "nosniff"
		# Don't leak the full URL to third parties.
		Referrer-Policy "strict-origin-when-cross-origin"
		# No camera/mic/geolocation needed.
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
		# Lock down sources. script-src pins the one inline theme snippet in
		# index.html by hash; previews use blob:, the annotated chart uses data:;
		# fonts come from Google Fonts. Regenerate the script hash if that inline
		# snippet changes.
		Content-Security-Policy "default-src 'self'; script-src 'self' 'sha256-3iy0OS2lbhFVDVYON8J51B0ehGrQf5/Vce7wK1NTjNo='; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob:; connect-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'"
		# Belt-and-suspenders against framing (older browsers ignore CSP's frame-ancestors).
		X-Frame-Options "DENY"
		# Don't advertise the server software.
		-Server
	}

	# API → FastAPI backend. Reject oversized uploads at the edge (matches the
	# backend's MAX_UPLOAD_BYTES) so huge bodies never reach Python.
	handle /api/* {
		request_body {
			max_size 1MB
		}
		# Hand the real client IP to the backend for per-IP rate limiting. The
		# backend is internal-only, so it trusts this header unconditionally.
		reverse_proxy backend:8000 {
			header_up X-Real-IP {client_ip}
		}
	}

	# Everything else → static frontend (nginx).
	handle {
		reverse_proxy frontend:80
	}
}
