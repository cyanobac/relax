# Copy to .env and fill in before `docker compose up` in production.

# Your domain (Caddy auto-provisions HTTPS via Let's Encrypt for a real name).
# Use "localhost" for local testing (Caddy serves an internal self-signed cert).
DOMAIN=stress.example.com

# Basic-auth credentials guarding the whole site.
BASIC_AUTH_USER=admin
# Generate the hash (do NOT commit the plaintext):
#   docker run caddy:2-alpine caddy hash-password --plaintext 'your-password'
BASIC_AUTH_HASH=
